import pandas as pd
import os
from datetime import datetime

class AgenticPaymentTracker:
    def __init__(self, folder_path="Agentic_Payments"):
        self.folder_path = folder_path
        self.tracking_file = os.path.join(folder_path, "bulk_savings_log_2026.csv")
        
        # Initialize folder and file if they don't exist
        if not os.path.exists(self.folder_path):
            os.makedirs(self.folder_path)
        
        if not os.path.isfile(self.tracking_file):
            pd.DataFrame(columns=["Timestamp", "Node", "Region", "Units", "Savings", "Contract"]).to_csv(self.tracking_file, index=False)

    def process_batch(self, node_id, units, region_id):
        threshold = 200
        discount_per_unit = 0.18
        
        if units >= threshold:
            savings = units * discount_per_unit
            contract = "RTVU1914/VUW1913"
            
            # Log the payment/savings event
            new_entry = {
                "Timestamp": datetime.now().strftime("%Y-%m-%d %H:%M"),
                "Node": node_id,
                "Region": region_id,
                "Units": units,
                "Savings": f"${savings:.2f}",
                "Contract": contract
            }
            
            # Append to tracking file
            df = pd.read_csv(self.tracking_file)
            df = pd.concat([df, pd.DataFrame([new_entry])], ignore_index=True)
            df.to_csv(self.tracking_file, index=False)
            
            return True, savings, contract
        return False, threshold - units, None

# --- EXECUTION ---
tracker = AgenticPaymentTracker()
node = "CAE2308742"
units_in_queue = 215
region = 211 # USA

is_eligible, result_val, contract_id = tracker.process_batch(node, units_in_queue, region)

print(f"--- AGENTIC PAYMENTS SYSTEM ---")
if is_eligible:
    print(f"BATCH LOGGED: {node}")
    print(f"SAVINGS TRACKED: ${result_val:.2f}")
    print(f"AUDIT STAMPS: {contract_id}")
    print(f"FILE UPDATED: {tracker.tracking_file}")
else:
    print(f"STATUS: Below Threshold. Gap: {result_val} units.")
